{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "oag_action_graph.schema.json",
  "title": "OAG Action Dependency Graph",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "generated_at",
    "ip",
    "mission_template",
    "nodes",
    "edges"
  ],
  "properties": {
    "schema_version": {
      "const": "oag_action_graph.v1"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "ip": {
      "type": "string",
      "minLength": 1
    },
    "mission_template": {
      "type": "string",
      "pattern": "^MISSION_[A-Z0-9_]+$"
    },
    "mission_instance_id": {
      "type": "string"
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "action_type", "status", "priority"],
        "properties": {
          "id": {
            "type": "string"
          },
          "action_type": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "priority": {
            "type": "string"
          },
          "score": {
            "type": "object"
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["from", "to", "kind", "reason"],
        "properties": {
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
