{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OAG Architecture Scoreboard",
  "type": "object",
  "required": ["schema_version", "ip", "run_id", "source_fingerprint", "rows", "rank_margin_pct"],
  "properties": {
    "schema_version": {
      "const": "oag_architecture_scoreboard.v1"
    },
    "ip": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_:-]+$"
    },
    "source_fingerprint": {
      "type": "string",
      "minLength": 1
    },
    "objective_weights": {
      "type": "object"
    },
    "rank_margin_pct": {
      "type": "number"
    },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["candidate_id", "rank", "weighted_total", "pareto_member", "metrics"],
        "properties": {
          "candidate_id": {
            "type": "string",
            "minLength": 1
          },
          "rank": {
            "type": "integer"
          },
          "weighted_total": {
            "type": "number"
          },
          "pareto_member": {
            "type": "boolean"
          },
          "rank_margin_pct": {
            "type": "number"
          },
          "metrics": {
            "type": "object"
          },
          "decision_assignments": {
            "type": "object"
          },
          "hard_constraint_pass": {
            "type": "boolean"
          },
          "constraint_issues": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": true
}
