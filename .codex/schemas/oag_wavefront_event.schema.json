{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "oag_wavefront_event.schema.json",
  "title": "OAG Wavefront Event",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "product_name",
    "internal_gateway",
    "run_id",
    "event",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "oag_wavefront_event.v1"
    },
    "product_name": {
      "const": "IP Dev Agent"
    },
    "internal_gateway": {
      "const": "Ontology Agent Gateway"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string"
    },
    "event": {
      "enum": ["planned", "ready", "claimed", "recorded", "verified", "closed", "blocked"]
    },
    "status": {
      "type": "string"
    },
    "details": {
      "type": "object"
    },
    "created_at": {
      "type": "string"
    }
  }
}
