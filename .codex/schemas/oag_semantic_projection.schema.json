{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "oag_semantic_projection.schema.json",
  "title": "OAG Semantic Projection",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "ip",
    "projections"
  ],
  "properties": {
    "schema_version": {
      "const": "oag_semantic_projection.v1"
    },
    "ip": {
      "type": "string",
      "minLength": 1
    },
    "projections": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "status",
          "load_bearing",
          "projection_class"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "ready",
              "blocked",
              "waived"
            ]
          },
          "load_bearing": {
            "type": "boolean"
          },
          "source_claim_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "requirement_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "atom_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "obligation_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "contract_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "projection_class": {
            "type": "string",
            "enum": [
              "preserved",
              "narrowed",
              "broadened",
              "defaulted",
              "waived",
              "blocked"
            ]
          },
          "authority_ref": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "input_hashes": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
