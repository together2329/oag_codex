{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "oag_wavefront_task_graph.schema.json",
  "title": "OAG Wavefront Task Graph",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "product_name",
    "internal_gateway",
    "run_id",
    "ip_id",
    "ip_dir",
    "tasks",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "const": "oag_wavefront_task_graph.v1"
    },
    "product_name": {
      "const": "IP Dev Agent"
    },
    "internal_gateway": {
      "const": "Ontology Agent Gateway"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "ip_id": {
      "type": "string",
      "minLength": 1
    },
    "ip_dir": {
      "type": "string",
      "minLength": 1
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "task_id",
          "kind",
          "phase",
          "depends_on",
          "allowed_write_paths",
          "ownership_mode",
          "status",
          "may_claim_complete"
        ],
        "properties": {
          "task_id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_.-]+$"
          },
          "kind": {
            "enum": ["read_only", "write", "integration", "closure"]
          },
          "phase": {
            "type": "string",
            "minLength": 1
          },
          "agent_type": {
            "type": "string"
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "barrier_inputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "barrier_outputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "allowed_write_paths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "shared_artifacts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "stale_if_paths_changed": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "pre_edit_hashes": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "ownership_mode": {
            "enum": ["none", "exclusive_file", "integration_owner"]
          },
          "status": {
            "enum": ["pending", "claimed", "handoff_pass", "blocked", "failed", "inconclusive", "waived", "closed"]
          },
          "claimed_by": {
            "type": "string"
          },
          "claimed_at": {
            "type": "string"
          },
          "may_claim_complete": {
            "const": false
          }
        }
      }
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}
