{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OAG Ambiguity Register",
  "type": "object",
  "required": ["schema_version", "ip", "ambiguities"],
  "properties": {
    "schema_version": {
      "const": "oag_ambiguity_register.v1"
    },
    "ip": {
      "type": "string",
      "minLength": 1
    },
    "ambiguities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "question", "status", "lock_required", "owner"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_:-]+$"
          },
          "question": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["open", "unresolved", "proposed", "resolved", "waived", "blocked"]
          },
          "lock_required": {
            "type": "boolean"
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "resolution": {
            "type": ["string", "number", "boolean", "object", "array", "null"]
          },
          "waiver_reason": {
            "type": ["string", "null"]
          },
          "source_claim_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "decision_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "affects": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
