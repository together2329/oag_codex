{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "oag_tb_authoring_packet.schema.json",
  "title": "OAG TB Authoring Packet",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "packet_type",
    "ip",
    "expected_source_policy",
    "forbidden_expected_sources",
    "scenario_refs",
    "scoreboard_row_refs",
    "contract_refs"
  ],
  "properties": {
    "schema_version": {
      "const": "oag_tb_authoring_packet.v1"
    },
    "packet_type": {
      "const": "tb_authoring_packet"
    },
    "ip": {
      "type": "string",
      "minLength": 1
    },
    "expected_source_policy": {
      "const": "contract_oracle_only"
    },
    "forbidden_expected_sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "scenario_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scoreboard_row_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "contract_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
