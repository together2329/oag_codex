{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "oag_rtl_authoring_packet.schema.json",
  "title": "OAG RTL Authoring Packet",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "packet_type",
    "ip",
    "allowed_truth_sources",
    "forbidden_sources",
    "contract_refs_to_implement"
  ],
  "properties": {
    "schema_version": {
      "const": "oag_rtl_authoring_packet.v1"
    },
    "packet_type": {
      "const": "rtl_authoring_packet"
    },
    "ip": {
      "type": "string",
      "minLength": 1
    },
    "allowed_truth_sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "forbidden_sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "contract_refs_to_implement": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "behavior_refs_implemented_target": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "cycle_rule_refs_implemented_target": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ppa_notes_required": {
      "type": "boolean"
    },
    "cdc_rdc_notes_required": {
      "type": "boolean"
    }
  }
}
