{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "oag_thread_execution.schema.json",
  "title": "OAG Worker Thread Execution",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "execution_kind",
    "dispatch_id",
    "dispatch_path",
    "thread_id",
    "turn_ids",
    "status",
    "model",
    "reasoning_effort",
    "started_at",
    "updated_at",
    "completed_at",
    "token_usage",
    "warning_sent",
    "budget_exceeded",
    "resume_count",
    "subagent_activity_count",
    "event_log_path",
    "event_log_sha256"
  ],
  "properties": {
    "schema_version": {"const": "oag_thread_execution.v1"},
    "execution_kind": {"const": "worker_thread"},
    "dispatch_id": {"type": "string", "minLength": 1},
    "dispatch_path": {"type": "string", "minLength": 1},
    "thread_id": {"type": "string", "minLength": 1},
    "turn_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "status": {"enum": ["running", "completed", "interrupted", "failed"]},
    "model": {"type": "string", "minLength": 1},
    "reasoning_effort": {"enum": ["none", "minimal", "low", "medium", "high", "xhigh"]},
    "model_source": {"enum": ["role_default", "cli_override", "resume_manifest"]},
    "reasoning_effort_source": {"enum": ["role_default", "cli_override", "resume_manifest"]},
    "sandbox": {"enum": ["read-only", "workspace-write", "danger-full-access"]},
    "sandbox_source": {"enum": ["role_default", "cli_override"]},
    "role_definition": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "source_path",
        "source_sha256",
        "catalog_path",
        "catalog_sha256",
        "common_preamble_path",
        "common_preamble_sha256",
        "default_model",
        "default_reasoning_effort",
        "default_sandbox"
      ],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "kind": {"enum": ["core", "custom"]},
        "source_path": {"type": "string", "pattern": "^\\.codex/agents/[A-Za-z0-9_-]+\\.toml$"},
        "source_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "catalog_path": {"const": ".codex/oag/agent-catalog.toml"},
        "catalog_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "common_preamble_path": {"const": ".codex/oag/agent-common-preamble.md"},
        "common_preamble_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "default_model": {"type": "string", "minLength": 1},
        "default_reasoning_effort": {"enum": ["none", "minimal", "low", "medium", "high", "xhigh"]},
        "default_sandbox": {"enum": ["read-only", "workspace-write", "danger-full-access"]}
      }
    },
    "started_at": {"type": "string", "minLength": 1},
    "updated_at": {"type": "string", "minLength": 1},
    "completed_at": {"type": "string"},
    "token_usage": {
      "type": "object",
      "required": ["input_tokens", "cached_input_tokens", "output_tokens", "reasoning_output_tokens", "total_tokens"],
      "properties": {
        "input_tokens": {"type": "integer", "minimum": 0},
        "cached_input_tokens": {"type": "integer", "minimum": 0},
        "output_tokens": {"type": "integer", "minimum": 0},
        "reasoning_output_tokens": {"type": "integer", "minimum": 0},
        "total_tokens": {"type": "integer", "minimum": 0}
      }
    },
    "warning_sent": {"type": "boolean"},
    "budget_exceeded": {"type": "boolean"},
    "budget_warning_tokens": {"type": "integer", "minimum": 0},
    "budget_hard_stop_tokens": {"type": "integer", "minimum": 0},
    "budget_configured_max_tokens": {"type": "integer", "minimum": 0},
    "resume_count": {"type": "integer", "minimum": 0, "maximum": 3},
    "subagent_activity_count": {"type": "integer", "minimum": 0},
    "event_log_path": {"type": "string", "minLength": 1},
    "event_log_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "failure_reason": {"type": "string"}
  }
}
