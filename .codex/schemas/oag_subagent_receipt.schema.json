{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "oag_subagent_receipt.schema.json",
  "title": "OAG Subagent Receipt",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "product_name",
    "internal_gateway",
    "role_name",
    "shard_scope",
    "stage",
    "status",
    "owned_obligations",
    "contracts",
    "allowed_write_paths",
    "evidence_outputs",
    "may_claim_complete",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "oag_subagent_receipt.v1"
    },
    "product_name": {
      "const": "IP Dev Agent"
    },
    "internal_gateway": {
      "const": "Ontology Agent Gateway"
    },
    "ip_id": {
      "type": "string"
    },
    "role_name": {
      "type": "string",
      "pattern": "^oag-[a-z0-9_-]+$"
    },
    "registered_id": {
      "type": "string"
    },
    "shard_scope": {
      "type": "string",
      "minLength": 1
    },
    "stage": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": ["HANDOFF_PASS", "STATIC_HANDOFF_PASS", "PASS", "FAIL", "BLOCKED", "INCONCLUSIVE"]
    },
    "owned_obligations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "contracts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "allowed_write_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "may_claim_complete": {
      "const": false
    },
    "created_at": {
      "type": "string"
    }
  }
}
