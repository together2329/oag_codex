{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OAG Decision Matrix",
  "type": "object",
  "required": ["schema_version", "ip", "decisions"],
  "properties": {
    "schema_version": {
      "const": "oag_decision_matrix.v1"
    },
    "ip": {
      "type": "string",
      "minLength": 1
    },
    "policy": {
      "type": "object"
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "question", "status", "lock_required", "owner"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_:-]+$"
          },
          "question": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["unresolved", "proposed", "decided", "waived", "blocked"]
          },
          "lock_required": {
            "type": "boolean"
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "decision_class": {
            "type": "string",
            "enum": ["fact", "parameterizable", "architecture_tradeoff", "product_defining"]
          },
          "autonomy_class": {
            "type": "string",
            "enum": ["fact", "reversible_internal", "measured_tradeoff", "external_contract"]
          },
          "resolution_strategy": {
            "type": "string",
            "enum": ["cite", "parameterize", "generate_option", "measure_and_select", "parameterized_default", "defer", "ask"]
          },
          "representation": {
            "type": "string",
            "enum": ["truth", "parameter", "generate_option"]
          },
          "external_contract_impact": {
            "type": "string",
            "enum": ["none", "indirect", "direct"]
          },
          "rollback_cost": {
            "type": ["string", "number", "object", "null"]
          },
          "candidate_values": {
            "type": "array"
          },
          "selection_rule": {
            "type": ["string", "object", "null"]
          },
          "evidence_required": {
            "type": "array",
            "items": {
              "type": ["string", "object"]
            }
          },
          "decided_by": {
            "type": "object",
            "properties": {
              "kind": {
                "type": "string",
                "enum": ["human", "spec", "agent_with_evidence", "agent_with_charter"]
              },
              "id": {
                "type": "string"
              },
              "charter_ref": {
                "type": "string"
              }
            },
            "additionalProperties": true
          },
          "provisional": {
            "type": "boolean"
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "decision_receipt_ref": {
            "type": "string",
            "minLength": 1
          },
          "decision": {
            "type": ["string", "number", "boolean", "object", "array", "null"]
          },
          "recommended": {
            "type": ["string", "number", "boolean", "object", "array", "null"]
          },
          "rationale": {
            "type": ["string", "null"]
          },
          "waiver_reason": {
            "type": ["string", "null"]
          },
          "affects": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
