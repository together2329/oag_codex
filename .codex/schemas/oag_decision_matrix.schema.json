{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OAG Decision Matrix",
  "type": "object",
  "required": ["schema_version", "ip", "decisions"],
  "properties": {
    "schema_version": {
      "const": "oag_decision_matrix.v1"
    },
    "ip": {
      "type": "string",
      "minLength": 1
    },
    "policy": {
      "type": "object"
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "question", "status", "lock_required", "owner"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_:-]+$"
          },
          "question": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["unresolved", "proposed", "decided", "waived", "blocked"]
          },
          "lock_required": {
            "type": "boolean"
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "decision": {
            "type": ["string", "number", "boolean", "object", "array", "null"]
          },
          "recommended": {
            "type": ["string", "number", "boolean", "object", "array", "null"]
          },
          "rationale": {
            "type": ["string", "null"]
          },
          "waiver_reason": {
            "type": ["string", "null"]
          },
          "affects": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
