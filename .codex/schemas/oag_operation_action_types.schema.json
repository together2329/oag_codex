{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "oag_operation_action_types.schema.json",
  "title": "OAG Operation Action Types",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "product_name",
    "internal_gateway",
    "action_types"
  ],
  "properties": {
    "schema_version": {
      "const": "oag_operation_action_types.v1"
    },
    "product_name": {
      "const": "IP Dev Agent"
    },
    "internal_gateway": {
      "const": "Ontology Agent Gateway"
    },
    "policy": {
      "type": "object"
    },
    "action_types": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "label",
          "phase",
          "owner_role",
          "consumes",
          "preconditions",
          "produces",
          "allowed_write_policy"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^ACT_[A-Z0-9_]+$"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "phase": {
            "type": "string",
            "minLength": 1
          },
          "owner_role": {
            "type": "string",
            "minLength": 1
          },
          "consumes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "preconditions": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "produces": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "allowed_write_policy": {
            "type": "object",
            "required": ["source", "required"],
            "properties": {
              "source": {
                "type": "string",
                "minLength": 1
              },
              "required": {
                "type": "boolean"
              }
            },
            "additionalProperties": true
          },
          "cannot_claim": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "fallback_policy": {
            "type": "object"
          },
          "timeout_policy": {
            "type": "object"
          },
          "question_policy": {
            "type": "object"
          }
        }
      }
    }
  }
}
