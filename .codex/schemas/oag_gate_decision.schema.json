{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "oag_gate_decision.schema.json",
  "title": "OAG Gate Decision",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "product_name",
    "internal_gateway",
    "ip_id",
    "role_name",
    "decision",
    "validation_report",
    "checked_artifacts",
    "checked_artifact_hashes",
    "blockers",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "oag_gate_decision.v1"
    },
    "product_name": {
      "const": "IP Dev Agent"
    },
    "internal_gateway": {
      "const": "Ontology Agent Gateway"
    },
    "ip_id": {
      "type": "string",
      "minLength": 1
    },
    "role_name": {
      "const": "oag-gate-reviewer"
    },
    "decision": {
      "enum": ["PASS", "FAIL", "BLOCKED", "WAIVED_WITH_RISK"]
    },
    "validation_report": {
      "type": "string",
      "minLength": 1
    },
    "checked_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "checked_artifact_hashes": {
      "type": "object"
    },
    "blockers": {
      "type": "array"
    },
    "created_at": {
      "type": "string"
    }
  }
}
