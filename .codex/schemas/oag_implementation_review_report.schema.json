{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "oag_implementation_review_report.schema.json",
  "title": "OAG Implementation Review Report",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "product_name",
    "internal_gateway",
    "ip_id",
    "role_name",
    "evidence_kind",
    "status",
    "source_truth_refs",
    "checked_artifacts",
    "findings",
    "ranked_next_actions",
    "may_claim_complete",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "oag_implementation_review_report.v1"
    },
    "product_name": {
      "const": "IP Dev Agent"
    },
    "internal_gateway": {
      "const": "Ontology Agent Gateway"
    },
    "ip_id": {
      "type": "string",
      "minLength": 1
    },
    "role_name": {
      "type": "string",
      "pattern": "^oag-[a-z0-9_-]+$"
    },
    "evidence_kind": {
      "const": "implementation_review"
    },
    "status": {
      "enum": ["pass", "fail", "blocked", "inconclusive"]
    },
    "source_truth_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "checked_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["contract_id", "implementation_status"],
        "properties": {
          "requirement_id": {
            "type": "string"
          },
          "obligation_id": {
            "type": "string"
          },
          "contract_id": {
            "type": "string",
            "minLength": 1
          },
          "module_id": {
            "type": "string"
          },
          "implementation_status": {
            "enum": ["implemented", "partial", "missing", "unverifiable", "not_applicable"]
          },
          "priority": {
            "enum": ["P0", "P1", "P2", "P3"]
          },
          "depends_on_contracts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "depends_on_actions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "confidence": {
            "enum": ["high", "medium", "low"]
          },
          "rtl_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "checked_artifacts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "missing": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "blockers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "recommended_next_action": {
            "type": "string"
          }
        }
      }
    },
    "ranked_next_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "priority", "contract_id", "status", "summary"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "priority": {
            "enum": ["P0", "P1", "P2", "P3"]
          },
          "contract_id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": ["blocked", "ready", "planned", "in_progress", "deferred"]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "target_agent": {
            "type": "string"
          },
          "target_artifacts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "depends_on_contracts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "parallel_group": {
            "type": "string"
          },
          "wavefront_task_hint": {
            "type": "string"
          }
        }
      }
    },
    "issues": {
      "type": "array"
    },
    "may_claim_complete": {
      "const": false
    },
    "created_at": {
      "type": "string"
    }
  }
}
