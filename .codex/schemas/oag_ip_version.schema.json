{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "oag_ip_version.schema.json",
  "title": "OAG IP Version Ledger",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "ip",
    "current_version",
    "version_policy",
    "versions"
  ],
  "properties": {
    "schema_version": {
      "const": "oag_ip_version.v1"
    },
    "ip": {
      "type": "string",
      "minLength": 1
    },
    "current_version": {
      "type": "string",
      "minLength": 1
    },
    "version_policy": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "git_scope",
        "tag_prefix"
      ],
      "properties": {
        "git_scope": {
          "enum": [
            "ip_local_repo"
          ]
        },
        "tag_prefix": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "versions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "version",
          "baseline_class",
          "state",
          "change_class",
          "functional_truth_changed",
          "baseline_manifest",
          "git_tag",
          "approval_ref"
        ],
        "properties": {
          "version": {
            "type": "string",
            "minLength": 1
          },
          "baseline_class": {
            "enum": [
              "candidate",
              "golden",
              "release",
              "archived"
            ]
          },
          "state": {
            "enum": [
              "draft",
              "active",
              "superseded",
              "revoked"
            ]
          },
          "change_class": {
            "enum": [
              "major",
              "minor",
              "patch",
              "initial"
            ]
          },
          "functional_truth_changed": {
            "type": "boolean"
          },
          "baseline_manifest": {
            "type": "string"
          },
          "git_tag": {
            "type": "string"
          },
          "approval_ref": {
            "type": "string"
          }
        }
      }
    }
  }
}
