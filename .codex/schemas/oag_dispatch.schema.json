{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "oag_dispatch.schema.json",
  "title": "OAG Subagent Dispatch",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "product_name",
    "internal_gateway",
    "dispatch_id",
    "agent_type",
    "role_name",
    "role_kind",
    "registered_id",
    "ip_id",
    "ip_dir",
    "stage",
    "owned_obligations",
    "contracts",
    "allowed_write_paths",
    "allowed_tool_side_effects",
    "receipt_path",
    "may_claim_complete",
    "baseline",
    "dispatch_integrity",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "oag_dispatch.v1"
    },
    "product_name": {
      "const": "IP Dev Agent"
    },
    "internal_gateway": {
      "const": "Ontology Agent Gateway"
    },
    "dispatch_id": {
      "type": "string",
      "pattern": "^DISPATCH_[A-Z0-9_]+_[0-9]{8}T[0-9]{6}Z(_[A-F0-9]{8})?$"
    },
    "agent_type": {
      "type": "string",
      "pattern": "^oag-[a-z0-9_-]+$"
    },
    "role_name": {
      "type": "string",
      "pattern": "^oag-[a-z0-9_-]+$"
    },
    "role_kind": {
      "enum": ["core", "custom"]
    },
    "registered_id": {
      "type": "string"
    },
    "ip_id": {
      "type": "string",
      "minLength": 1
    },
    "ip_dir": {
      "type": "string",
      "minLength": 1
    },
    "stage": {
      "type": "string",
      "minLength": 1
    },
    "owned_obligations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "contracts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "allowed_write_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "allowed_tool_side_effects": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "receipt_path": {
      "type": "string",
      "minLength": 1
    },
    "wavefront_run_id": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "ownership_mode": {
      "type": "string"
    },
    "execution_budget": {
      "type": "object",
      "required": ["schema_version", "complexity", "max_total_tokens", "warning_total_tokens", "max_review_attempts", "over_budget_action", "model_tier"],
      "properties": {
        "schema_version": {"const": "oag_execution_budget.v1"},
        "complexity": {"enum": ["simple", "medium", "complex"]},
        "max_total_tokens": {"type": "integer", "minimum": 100000, "maximum": 25000000},
        "warning_total_tokens": {"type": "integer", "minimum": 80000, "maximum": 20000000},
        "max_review_attempts": {"type": "integer", "minimum": 0, "maximum": 2},
        "over_budget_action": {"const": "stop_and_replan"},
        "model_tier": {"enum": ["mechanical", "balanced", "reasoning"]}
      }
    },
    "context_contract": {
      "type": "object",
      "required": ["schema_version", "fork_turns", "input_mode", "max_direct_source_files", "require_source_hashes", "repeat_review_policy"],
      "properties": {
        "schema_version": {"const": "oag_context_contract.v1"},
        "fork_turns": {"const": "none"},
        "input_mode": {"const": "authoring_packet_or_explicit_file_list"},
        "max_direct_source_files": {"type": "integer", "minimum": 1, "maximum": 64},
        "require_source_hashes": {"const": true},
        "repeat_review_policy": {"const": "content_hash_delta_only"}
      }
    },
    "may_claim_complete": {
      "const": false
    },
    "baseline": {
      "type": "object"
    },
    "dispatch_integrity": {
      "type": "object",
      "required": [
        "schema_version",
        "protected_fields",
        "scope_hash_algorithm",
        "scope_hash"
      ],
      "properties": {
        "schema_version": {
          "const": "oag_dispatch_integrity.v1"
        },
        "protected_fields": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "scope_hash_algorithm": {
          "const": "sha256:jcs-v1"
        },
        "scope_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "created_at": {
      "type": "string"
    }
  }
}
