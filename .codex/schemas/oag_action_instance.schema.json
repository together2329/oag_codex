{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "oag_action_instance.schema.json",
  "title": "OAG Action Instance",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "id",
    "action_type",
    "status",
    "selected_by",
    "selected_reason",
    "started_at",
    "target_objects",
    "result"
  ],
  "properties": {
    "schema_version": {
      "const": "oag_action_instance.v1"
    },
    "id": {
      "type": "string",
      "pattern": "^ACT_RUN_[A-Za-z0-9_.:-]+$"
    },
    "action_type": {
      "type": "string",
      "pattern": "^ACT_[A-Z0-9_]+$"
    },
    "candidate_ref": {
      "type": "string"
    },
    "mission_instance_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": ["started", "running", "accepted", "rejected", "blocked", "failed", "inconclusive", "aborted"]
    },
    "selected_by": {
      "type": "object",
      "required": ["kind", "id"],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "surface": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "selected_reason": {
      "type": "string",
      "minLength": 1
    },
    "started_at": {
      "type": "string",
      "minLength": 1
    },
    "completed_at": {
      "type": "string"
    },
    "target_objects": {
      "type": "object"
    },
    "result": {
      "type": "object"
    }
  }
}
