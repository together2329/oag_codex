{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "oag_requirement_atom.schema.json",
  "title": "OAG Requirement Atom File",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "ip",
    "requirement_atoms"
  ],
  "properties": {
    "schema_version": {
      "const": "oag_requirement_atoms.v1"
    },
    "ip": {
      "type": "string",
      "minLength": 1
    },
    "requirement_atoms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "source_requirement_id",
          "status",
          "normalized_text",
          "pattern",
          "boundary",
          "phenomena",
          "ambiguity"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^ATOM_[A-Z0-9_]+$"
          },
          "source_requirement_id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "draft",
              "candidate",
              "locked",
              "blocked"
            ]
          },
          "normalized_text": {
            "type": "string",
            "minLength": 1
          },
          "pattern": {
            "type": "object",
            "required": [
              "trigger",
              "response"
            ],
            "properties": {
              "trigger": {
                "type": "string",
                "minLength": 1
              },
              "condition": {
                "type": "string"
              },
              "response": {
                "type": "string",
                "minLength": 1
              },
              "timing": {
                "type": "string"
              },
              "exception": {
                "type": "string"
              }
            },
            "additionalProperties": true
          },
          "boundary": {
            "type": "object",
            "required": [
              "responsible_agent"
            ],
            "properties": {
              "responsible_agent": {
                "type": "string",
                "minLength": 1
              },
              "environment_agents": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          },
          "assumptions": {
            "type": "object"
          },
          "phenomena": {
            "type": "object",
            "additionalProperties": true
          },
          "ambiguity": {
            "type": "object",
            "properties": {
              "missing_terms": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "open_questions": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          }
        }
      }
    }
  }
}
