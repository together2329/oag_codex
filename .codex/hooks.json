{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .codex/hooks/codex_oag_session_start.py",
            "commandWindows": "cmd.exe /d /c .codex\\bin\\oag-python.cmd .codex\\hooks\\codex_oag_session_start.py",
            "timeout": 10,
            "statusMessage": "OAG: enforcing Codex subagent config"
          },
          {
            "type": "command",
            "command": "python3 .codex/hooks/codex_oag_telemetry.py",
            "commandWindows": "cmd.exe /d /c .codex\\bin\\oag-python.cmd .codex\\hooks\\codex_oag_telemetry.py",
            "timeout": 10,
            "statusMessage": "OAG: recording OTEL correlation identity"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .codex/hooks/codex_oag_mode_trigger.py",
            "commandWindows": "cmd.exe /d /c .codex\\bin\\oag-python.cmd .codex\\hooks\\codex_oag_mode_trigger.py",
            "timeout": 10,
            "statusMessage": "OAG: checking explicit mode trigger"
          },
          {
            "type": "command",
            "command": "python3 .codex/hooks/codex_native_subagent_guard.py",
            "commandWindows": "cmd.exe /d /c .codex\\bin\\oag-python.cmd .codex\\hooks\\codex_native_subagent_guard.py",
            "timeout": 10,
            "statusMessage": "OAG: enforcing native subagent guard"
          },
          {
            "type": "command",
            "command": "python3 .codex/hooks/codex_deep_interview_prompt_guard.py",
            "commandWindows": "cmd.exe /d /c .codex\\bin\\oag-python.cmd .codex\\hooks\\codex_deep_interview_prompt_guard.py",
            "timeout": 10,
            "statusMessage": "OAG: checking deep interview prompt discipline"
          },
          {
            "type": "command",
            "command": "python3 .codex/hooks/codex_context_inject.py",
            "commandWindows": "cmd.exe /d /c .codex\\bin\\oag-python.cmd .codex\\hooks\\codex_context_inject.py",
            "timeout": 10,
            "statusMessage": "OAG: injecting IP context"
          },
          {
            "type": "command",
            "command": "python3 .codex/hooks/codex_draft_pressure.py",
            "commandWindows": "cmd.exe /d /c .codex\\bin\\oag-python.cmd .codex\\hooks\\codex_draft_pressure.py",
            "timeout": 10,
            "statusMessage": "OAG: checking interview draft pressure"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .codex/hooks/codex_stop_gate.py",
            "commandWindows": "cmd.exe /d /c .codex\\bin\\oag-python.cmd .codex\\hooks\\codex_stop_gate.py",
            "timeout": 10,
            "statusMessage": "OAG: checking active run completion"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "^oag-",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .codex/hooks/codex_subagent_oag_start.py",
            "commandWindows": "cmd.exe /d /c .codex\\bin\\oag-python.cmd .codex\\hooks\\codex_subagent_oag_start.py",
            "timeout": 10,
            "statusMessage": "OAG: injecting subagent start contract"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "^oag-",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .codex/hooks/codex_subagent_oag_gate.py",
            "commandWindows": "cmd.exe /d /c .codex\\bin\\oag-python.cmd .codex\\hooks\\codex_subagent_oag_gate.py",
            "timeout": 10,
            "statusMessage": "OAG: verifying subagent evidence receipt"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .codex/hooks/codex_context_inject.py",
            "commandWindows": "cmd.exe /d /c .codex\\bin\\oag-python.cmd .codex\\hooks\\codex_context_inject.py",
            "timeout": 10,
            "statusMessage": "OAG: restoring IP context after compact"
          }
        ]
      }
    ]
  }
}
