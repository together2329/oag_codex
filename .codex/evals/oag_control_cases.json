{
  "schema_version": "oag_answer_key_suite.v1",
  "name": "oag_control_policy_seed",
  "description": "Seed answer-key cases for conversational OAG run-limit control and graph compile freshness.",
  "cases": [
    {
      "id": "run_limit_requirements_stops_before_sim",
      "kind": "run_limit_prompt",
      "input": {
        "prompt": "requirement 까지만"
      },
      "expected": {
        "configured_limit": "requirements",
        "context_configured": true,
        "stop_should_continue": false,
        "stop_reason": "policy_limit_reached",
        "next_action_stage": "sim",
        "stop_hook_blocked": false
      },
      "speed": {
        "max_duration_s": 4.0
      }
    },
    {
